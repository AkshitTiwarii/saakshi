// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {uid}
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - displayName: string (optional) - User display name
//   - photoURL: string (optional) - User photo URL
//   - role: string (required) - 'user' or 'admin'
//   - createdAt: timestamp (required) - Creation time
//
// Collection: fragments
// Document ID: {fragmentId}
// Fields:
//   - uid: string (required) - Owner UID
//   - type: string (required) - 'text', 'voice', 'drawing'
//   - content: string (required) - Raw content or storage ref
//   - emotion: string (optional) - Detected emotion
//   - timestamp: timestamp (required) - Capture time
//   - classification: map (optional) - AI classification
//
// Collection: evidence
// Document ID: {evidenceId}
// Fields:
//   - uid: string (required) - Owner UID
//   - source: string (required) - 'IMD', 'Ola', etc.
//   - status: string (required) - 'found', 'verified', 'searching'
//   - details: string (optional) - Evidence details
//   - timestamp: timestamp (required) - Verification time
//
// Collection: cases
// Document ID: {caseId}
// Fields:
//   - uid: string (required) - Owner UID
//   - title: string (optional) - Case title
//   - strengthScore: number (required) - 0-100
//   - adversarialAnalysis: map (optional) - VIRODHI/RAKSHA data
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "akshittiwari29@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    function isValidFragment(data) {
      return hasOnlyAllowedFields(['uid', 'type', 'content', 'emotion', 'timestamp', 'classification', 'geoTag', 'fileType', 'fileName']) &&
             data.uid is string &&
             data.type in ['text', 'voice', 'drawing', 'upload'] &&
             data.content is string &&
             data.timestamp is timestamp;
    }

    function isValidEvidence(data) {
      return hasOnlyAllowedFields(['uid', 'source', 'status', 'details', 'timestamp', 'query']) &&
             data.uid is string &&
             data.source is string &&
             data.status in ['found', 'verified', 'searching'] &&
             data.timestamp is timestamp;
    }

    function isValidCase(data) {
      return hasOnlyAllowedFields(['uid', 'title', 'strengthScore', 'adversarialAnalysis', 'createdAt', 'updatedAt']) &&
             data.uid is string &&
             data.strengthScore is number &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /fragments/{fragmentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidFragment(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidFragment(request.resource.data) && isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /evidence/{evidenceId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidEvidence(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidEvidence(request.resource.data) && isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /cases/{caseId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCase(request.resource.data) && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && isValidCase(request.resource.data) && isDocOwner() && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
