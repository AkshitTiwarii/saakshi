# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Firebase Web API key (for web app initialization in src/firebase.ts)
VITE_FIREBASE_API_KEY=""

# Firebase Web API key (for Expo mobile initialization in mobile-app/src/services/firebaseService.ts)
EXPO_PUBLIC_FIREBASE_API_KEY=""

# Optional model override used by Saakshi AI routes (including Virodhi).
GEMINI_MODEL="gemini-2.5-flash"

# Optional Vertex AI key/model used by voice transcription fallback.
# Keep this server-side only. Do not commit real keys.
VERTEX_API_KEY=""
VERTEX_MODEL="gemini-2.5-flash-lite"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Google Cloud service account JSON file path used by backend NLP + Speech clients.
# Example on Windows:
# GOOGLE_APPLICATION_CREDENTIALS="C:/Users/<you>/Downloads/my-service-account.json"
GOOGLE_APPLICATION_CREDENTIALS=""

# Optional Google Pay / merchant transaction lookup config for Khojak payment evidence.
GOOGLE_MERCHANT_ID=""
GOOGLE_PAY_ACCESS_TOKEN=""
