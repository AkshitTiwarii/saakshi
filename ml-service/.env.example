# Hugging Face model to use for Indian law predictions
HF_LAW_MODEL_ID=nisaar/falcon7b-Indian_Law_150Prompts_800steps_5epoch


# Set your Hugging Face token for API inference
HF_API_TOKEN=

# hf-api (recommended) or local (requires high VRAM/CPU resources)
LAW_MODEL_PROVIDER=hf-api

# Used only when LAW_MODEL_PROVIDER=local
LAW_LOCAL_MAX_NEW_TOKENS=180

# Ensemble configuration
LEGAL_ENSEMBLE_ENABLED=true
LEGAL_ENSEMBLE_MODELS=nisaar/LLAMA2_Constitution_Of_India,nisaar/falcon7b-Articles_Constitution_instruction_set_4epochs_8000maxsteps,nisaar/falcon7b-Articles_Constitution_instruction_set_4epochs_15000maxsteps,nisaar/falcon7b-Article19_instruction_set_4epochs_2400maxsteps,nisaar/falcon7b-Indian_Law_150Prompts_800steps_5epoch_1,nisaar/falcon7b-Constitution_of_India_933Prompts_2000steps_2epoch
LEGAL_ENSEMBLE_WEIGHTS=1,1,1.2,1,1.4,1.1

# InLegalBERT constitutional signal
INLEGAL_BERT_ENABLED=true
INLEGAL_BERT_MODEL_ID=law-ai/InLegalBERT
